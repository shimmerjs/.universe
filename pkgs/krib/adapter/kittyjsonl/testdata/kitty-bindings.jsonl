{"kitty_mod": "ctrl+opt+shift"}
{"mode": "default", "keys": "ctrl+cmd+,", "action": "load_config_file"}
{"mode": "default", "keys": "f1", "action": "show_kitty_doc conf"}
{"mode": "default", "keys": "f2", "action": "launch --type=overlay --hold --allow-remote-control sh -c \"kitten @ kitten kits/keybindings.py | /nix/store/whmw2ihgvdlmm0j3jw6y5s7yjr48242x-kittykrib-0/bin/cheatsheet\""}
{"mode": "default", "keys": "kitty_mod+f3", "action": "command_palette"}
