{"mode": "default", "keys": "kitty_mod+p > n", "action": "kitten hints --type linenum"}
{"mode": "mw", "keys": "left", "action": "move_window left"}
{"mode": "mw", "keys": "right", "action": "move_window right"}
{"mode": "mw", "keys": "escape", "action": "pop_keyboard_mode"}
