{"mode": "default", "keys": "cmd+c", "action": "copy_or_noop"}
{"mode": "default", "keys": "cmd+v", "action": "paste_from_clipboard"}
{"mode": "default", "keys": "cmd+n", "action": "new_os_window"}
{"mode": "default", "keys": "cmd+q", "action": "quit"}
{"mode": "default", "keys": "cmd+enter", "action": "new_window_with_cwd"}
{"mode": "default", "keys": "cmd+]", "action": "next_window"}
{"mode": "default", "keys": "cmd+[", "action": "previous_window"}
{"mode": "default", "keys": "cmd+w", "action": "close_window"}
{"mode": "default", "keys": "cmd+1", "action": "first_window"}
{"mode": "default", "keys": "cmd+2", "action": "second_window"}
{"mode": "default", "keys": "cmd+3", "action": "third_window"}
{"mode": "default", "keys": "cmd+4", "action": "fourth_window"}
{"mode": "default", "keys": "cmd+5", "action": "fifth_window"}
{"mode": "default", "keys": "cmd+6", "action": "sixth_window"}
{"mode": "default", "keys": "cmd+r", "action": "start_resizing_window"}
{"mode": "default", "keys": "ctrl+shift+f", "action": "move_window_forward"}
{"mode": "default", "keys": "ctrl+shift+b", "action": "move_window_backward"}
{"mode": "default", "keys": "ctrl+shift+t", "action": "move_window_to_top"}
{"mode": "default", "keys": "shift+cmd+l", "action": "next_layout"}
{"mode": "default", "keys": "kitty_mod+enter", "action": "launch --location=hsplit --cwd=current"}
{"mode": "default", "keys": "kitty_mod+cmd+enter", "action": "launch --location=vsplit --cwd=current"}
{"mode": "default", "keys": "ctrl+shift+enter", "action": "launch --location=split --cwd=current"}
{"mode": "default", "keys": "ctrl+shift+r", "action": "layout_action rotate"}
{"mode": "default", "keys": "cmd+t", "action": "new_tab_with_cwd"}
{"mode": "default", "keys": "shift+cmd+]", "action": "next_tab"}
{"mode": "default", "keys": "shift+cmd+[", "action": "previous_tab"}
{"mode": "default", "keys": "shift+cmd+w", "action": "close_tab"}
{"mode": "default", "keys": "kitty_mod+.", "action": "move_tab_forward"}
{"mode": "default", "keys": "kitty_mod+,", "action": "move_tab_backward"}
{"mode": "default", "keys": "shift+cmd+e", "action": "launch --type=overlay --allow-remote-control /nix/store/w0983y6gqvyw55gzzsijqhgy7g4qafcw-kitty-tab-switcher/bin/kitty-tab-switcher"}
{"mode": "default", "keys": "shift+cmd+h", "action": "show_scrollback"}
{"mode": "default", "keys": "shift+cmd+g", "action": "show_last_non_empty_command_output"}
{"mode": "default", "keys": "kitty_mod+c", "action": "copy_last_command_output"}
{"mode": "default", "keys": "cmd+k", "action": "clear_terminal clear active"}
{"mode": "default", "keys": "opt+cmd+k", "action": "clear_terminal scroll active"}
{"mode": "default", "keys": "cmd+l", "action": "clear_terminal last_command active"}
{"mode": "default", "keys": "cmd+up", "action": "scroll_line_up"}
{"mode": "default", "keys": "cmd+down", "action": "scroll_line_down"}
{"mode": "default", "keys": "cmd+page_up", "action": "scroll_page_up"}
{"mode": "default", "keys": "cmd+page_down", "action": "scroll_page_down"}
{"mode": "default", "keys": "cmd++", "action": "change_font_size all + 2.0"}
{"mode": "default", "keys": "cmd+=", "action": "change_font_size all + 2.0"}
{"mode": "default", "keys": "cmd+-", "action": "change_font_size all - 2.0"}
{"mode": "default", "keys": "cmd+0", "action": "change_font_size all 0"}
{"mode": "default", "keys": "kitty_mod+p > f", "action": "kitten hints --type path --program -"}
